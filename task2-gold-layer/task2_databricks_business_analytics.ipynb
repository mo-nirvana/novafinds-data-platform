# DBTITLE 1,products most profitable
# MAGIC %sql
# MAGIC -- Product Revenue Analysis (Gold Layer)
# MAGIC -- Purpose: Estimate revenue per product based on related orders
# MAGIC -- 
# MAGIC -- Metrics:
# MAGIC --   - related_revenue: Sum of unified_amount from orders where product_id occurred
# MAGIC --   - total_quantity: Units sold
# MAGIC --   - total_cost: Product cost (price * quantity)
# MAGIC --
# MAGIC -- Use Cases:
# MAGIC --   - Estimate product revenue from orders
# MAGIC --   - Product portfolio analysis
# MAGIC
# MAGIC CREATE OR REPLACE TABLE product_revenue_gold AS (
# MAGIC SELECT 
# MAGIC   p.product_id, 
# MAGIC   p.product_name, 
# MAGIC   p.category_name,
# MAGIC   p.price,
# MAGIC   SUM(o.quantity) AS total_quantity,
# MAGIC   SUM(o.quantity * p.price) AS total_cost,
# MAGIC   SUM(o.unified_amount) AS related_revenue
# MAGIC FROM product_silver p
# MAGIC JOIN order_silver o
# MAGIC   ON p.product_id = o.product_id
# MAGIC GROUP BY p.category_name, p.product_id, p.product_name, p.price
# MAGIC );
# MAGIC
# MAGIC -- Preview: Top 10 products by related revenue
# MAGIC SELECT * FROM product_revenue_gold ORDER BY related_revenue DESC LIMIT 10

