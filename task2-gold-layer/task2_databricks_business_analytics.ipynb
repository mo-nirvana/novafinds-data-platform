   "source": [
    "%sql\n",
    "CREATE TABLE IF NOT EXISTS stripe_payments AS\n",
    "SELECT * \n",
    "FROM read_files(\n",
    "  '/Volumes/main/novafinds/stripe/20251230_stripe_payments.json',\n",
    "  format => 'JSON',\n",
    "  multiLine => true\n",
    ");\n",
    "\n",
    "SELECT data from stripe_payments limit 5"
   ]
